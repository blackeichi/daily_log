# 환경 설정
NODE_ENV=development
PORT=4000

# 데이터베이스 설정
DATABASE_URL="postgresql://username:password@localhost:5432/daily_log_db?schema=public"

# JWT 설정
JWT_ACCESS_SECRET=your-super-secret-access-token-key-here-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-token-key-here-min-32-chars

# 회원가입 시크릿 키
SIGN_UP_SECRET_KEY=your-signup-secret-key

# 게스트 계정 (체험용)
GUEST_EMAIL=guest@example.com
GUEST_PASSWORD=guest123


# CORS 허용 도메인 (쉼표로 구분)
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
